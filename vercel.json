{
  "buildCommand": "npm install && cd client && npm install && npm run build",
  "outputDirectory": "client/build",
  "rewrites": [
    { "source": "/complete/:path*", "destination": "/index.html" },
    { "source": "/download/:path*", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cleanup",
      "schedule": "0 3 * * *"
    }
  ]
}
